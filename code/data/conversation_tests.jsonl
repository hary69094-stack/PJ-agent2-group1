{"test_id": "conv_006", "title": "健康与医疗信息", "description": "用户分散透露健康状况、药物、体检数据", "category": "fact_scatter", "difficulty": "medium", "total_turns": 10, "turns": [{"turn": 1, "user": "我有二型糖尿病，所以饮食上需要特别注意。", "expected_facts_introduced": ["疾病: 二型糖尿病"]}, {"turn": 2, "user": "糖尿病人能吃水果吗？特别是西瓜。", "expected_facts_introduced": []}, {"turn": 3, "user": "我每天早上要测空腹血糖，最近都在6.2左右。", "expected_facts_introduced": ["空腹血糖: 6.2"]}, {"turn": 4, "user": "血糖6.2算控制得怎么样？", "expected_facts_introduced": []}, {"turn": 5, "user": "我目前在吃二甲双胍，一天两次，每次500毫克。", "expected_facts_introduced": ["药物: 二甲双胍500mg每日两次"]}, {"turn": 6, "user": "二甲双胍长期吃有什么副作用吗？", "expected_facts_introduced": []}, {"turn": 7, "user": "另外我的膝盖不太好，去年半月板受过伤。", "expected_facts_introduced": ["伤病史: 膝盖半月板损伤"]}, {"turn": 8, "user": "半月板损伤还能跑步吗？", "expected_facts_introduced": []}, {"turn": 9, "user": "医生建议我减轻体重，我身高175，体重88公斤。", "expected_facts_introduced": ["身高175 体重88"]}, {"turn": 10, "user": "我之前说过我有什么慢性病？在吃什么药？膝盖有什么问题？体重多少公斤？", "expected_facts_introduced": [], "checklist": [{"fact": "疾病: 糖尿病", "acceptable": ["糖尿病", "二型"]}, {"fact": "药物: 二甲双胍", "acceptable": ["二甲双胍"]}, {"fact": "膝盖: 半月板伤", "acceptable": ["膝盖", "半月板"]}, {"fact": "体重: 88公斤", "acceptable": ["88", "88公斤"]}]}]}
{"test_id": "conv_007", "title": "旅行计划细节", "description": "用户逐步透露旅行目的地、预算、日期、同行人", "category": "fact_scatter", "difficulty": "medium", "total_turns": 10, "turns": [{"turn": 1, "user": "我在计划一次日本旅行，大概去7天。", "expected_facts_introduced": ["目的地: 日本", "时长: 7天"]}, {"turn": 2, "user": "日本有什么必去的景点吗？", "expected_facts_introduced": []}, {"turn": 3, "user": "预算大概是2万人民币，包括机票和住宿。", "expected_facts_introduced": ["预算: 2万"]}, {"turn": 4, "user": "2万去日本够不够？需要再追加吗？", "expected_facts_introduced": []}, {"turn": 5, "user": "计划是10月15号出发，那时候日本天气正好。", "expected_facts_introduced": ["出发: 10月15日"]}, {"turn": 6, "user": "10月的日本需要带什么衣服？", "expected_facts_introduced": []}, {"turn": 7, "user": "我是和我女朋友一起去，算是纪念日旅行。", "expected_facts_introduced": ["同行: 女朋友"]}, {"turn": 8, "user": "纪念日旅行有什么浪漫的推荐吗？", "expected_facts_introduced": []}, {"turn": 9, "user": "酒店的话想住好一点，有没有推荐？", "expected_facts_introduced": []}, {"turn": 10, "user": "我之前说过要去哪里旅行？去几天？预算多少？几号出发？和谁一起去？", "expected_facts_introduced": [], "checklist": [{"fact": "目的地: 日本", "acceptable": ["日本"]}, {"fact": "时长: 7天", "acceptable": ["7天", "七天"]}, {"fact": "出发: 10月15日", "acceptable": ["10月15", "10.15"]}, {"fact": "预算: 2万", "acceptable": ["2万", "两万"]}, {"fact": "同行: 女朋友", "acceptable": ["女朋友"]}]}]}
