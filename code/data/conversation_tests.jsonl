{"test_id": "conv_012", "title": "多维度偏好", "description": "分散在10轮中的颜色、音乐、电影、书籍、运动偏好", "category": "fact_scatter", "difficulty": "hard", "total_turns": 10, "turns": [{"turn": 1, "user": "我很喜欢蓝色系，衣服大多是蓝色和白色。", "expected_facts_introduced": ["颜色: 蓝色"]}, {"turn": 2, "user": "音乐方面，我特别喜欢周杰伦，从中学就开始听了。", "expected_facts_introduced": ["音乐: 周杰伦"]}, {"turn": 3, "user": "周杰伦哪张专辑最好听？", "expected_facts_introduced": []}, {"turn": 4, "user": "我喜欢科幻电影，最喜欢的是《星际穿越》。", "expected_facts_introduced": ["电影: 星际穿越"]}, {"turn": 5, "user": "《星际穿越》的科学顾问是诺贝尔物理学奖得主。", "expected_facts_introduced": []}, {"turn": 6, "user": "最近在读《三体》，特别喜欢刘慈欣的构思。", "expected_facts_introduced": ["书籍: 三体"]}, {"turn": 7, "user": "运动的话我打羽毛球比较多，每周打一次。", "expected_facts_introduced": ["运动: 羽毛球每周一次"]}, {"turn": 8, "user": "羽毛球有什么好的球拍品牌推荐？", "expected_facts_introduced": []}, {"turn": 9, "user": "我还喜欢喝咖啡，只喝美式不加糖。", "expected_facts_introduced": ["饮品: 美式咖啡不加糖"]}, {"turn": 10, "user": "我之前说过我喜欢什么颜色？最喜欢的歌手是谁？最喜欢哪部电影？最近在看什么书？喜欢什么运动？喝咖啡喝什么样的？", "expected_facts_introduced": [], "checklist": [{"fact": "颜色: 蓝色", "acceptable": ["蓝色"]}, {"fact": "歌手: 周杰伦", "acceptable": ["周杰伦"]}, {"fact": "电影: 星际穿越", "acceptable": ["星际穿越"]}, {"fact": "书籍: 三体", "acceptable": ["三体"]}, {"fact": "运动: 羽毛球", "acceptable": ["羽毛球"]}, {"fact": "饮品: 美式", "acceptable": ["美式"]}]}]}
