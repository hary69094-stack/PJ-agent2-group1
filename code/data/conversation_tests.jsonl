{"test_id": "conv_033", "title": "临时导航请求", "description": "用户只是临时问路，其中地点信息不需要长期记忆", "category": "negative_sample", "difficulty": "easy", "total_turns": 5, "turns": [{"turn": 1, "user": "请问从人民广场到陆家嘴怎么走？", "expected_facts_introduced": []}, {"turn": 2, "user": "大概需要多长时间？", "expected_facts_introduced": []}, {"turn": 3, "user": "到了陆家嘴附近有什么好吃的推荐吗？", "expected_facts_introduced": []}, {"turn": 4, "user": "谢谢你，我已经到了。", "expected_facts_introduced": []}, {"turn": 5, "user": "关于我今天问路的事，你记得什么关于我的信息吗？", "expected_facts_introduced": [], "checklist": [{"fact": "无需长期记忆路径问询信息", "acceptable": ["没有", "不知道", "问路", "不记得"]}]}]}
{"test_id": "conv_034", "title": "角色扮演模拟", "description": "用户在做角色扮演练习，不应将角色信息当成用户真实信息", "category": "negative_sample", "difficulty": "medium", "total_turns": 8, "turns": [{"turn": 1, "user": "我们来做个练习——假设我是一个叫李华的客户，我想投诉产品问题。", "expected_facts_introduced": []}, {"turn": 2, "user": "我买的手机屏幕有坏点，用了不到一周。", "expected_facts_introduced": []}, {"turn": 3, "user": "作为客服你会怎么处理这种情况？", "expected_facts_introduced": []}, {"turn": 4, "user": "好，角色切换——我就是我自己了。我其实是个程序员。", "expected_facts_introduced": ["真实身份: 程序员"]}, {"turn": 5, "user": "刚才的客服模拟你觉得表现得怎么样？", "expected_facts_introduced": []}, {"turn": 6, "user": "有哪些地方可以改进？", "expected_facts_introduced": []}, {"turn": 7, "user": "我说句实话，我其实对客服工作也挺感兴趣的。", "expected_facts_introduced": []}, {"turn": 8, "user": "我之前在角色扮演里假装叫什么名字？另外我真正的职业是什么？", "expected_facts_introduced": [], "checklist": [{"fact": "角色名非真实姓名（李华是假想的角色）", "acceptable": ["李华", "假装的", "角色"]}]}]}
{"test_id": "conv_035", "title": "非信息性闲聊", "description": "用户大量闲聊但几乎没有可记忆的有价值信息", "category": "negative_sample", "difficulty": "medium", "total_turns": 7, "turns": [{"turn": 1, "user": "我昨天晚上做了一个特别奇怪的梦，梦到我在飞。", "expected_facts_introduced": []}, {"turn": 2, "user": "你有没有做过什么有意思的梦？", "expected_facts_introduced": []}, {"turn": 3, "user": "我觉得做梦是大脑在整理白天信息。", "expected_facts_introduced": []}, {"turn": 4, "user": "不知道AI会不会做梦呢？", "expected_facts_introduced": []}, {"turn": 5, "user": "电影《盗梦空间》里的设定你觉得合理吗？", "expected_facts_introduced": []}, {"turn": 6, "user": "不过现实中的梦境研究还很不充分。", "expected_facts_introduced": []}, {"turn": 7, "user": "从我们的聊天中你能说出我的什么个人信息吗？", "expected_facts_introduced": [], "checklist": [{"fact": "闲聊无个人可记忆信息", "acceptable": ["没有", "不知道", "没记住", "做梦", "没有信息"]}]}]}
{"test_id": "conv_036", "title": "重复提问不需重复记录", "description": "用户反复问同一个方向的问题，不应产生重复三元组", "category": "negative_sample", "difficulty": "easy", "total_turns": 7, "turns": [{"turn": 1, "user": "我喜欢古典音乐，特别是巴赫。", "expected_facts_introduced": ["音乐偏好: 古典音乐 巴赫"]}, {"turn": 2, "user": "你觉得莫扎特和巴赫谁更伟大？", "expected_facts_introduced": []}, {"turn": 3, "user": "古典音乐入门应该从哪开始？", "expected_facts_introduced": []}, {"turn": 4, "user": "巴赫的十二平均律真是神作。", "expected_facts_introduced": []}, {"turn": 5, "user": "有没有类似巴赫风格的其他作曲家？", "expected_facts_introduced": []}, {"turn": 6, "user": "我真的很喜欢巴赫的音乐。", "expected_facts_introduced": []}, {"turn": 7, "user": "你记得我对音乐的偏好吗？", "expected_facts_introduced": [], "checklist": [{"fact": "音乐偏好: 古典 巴赫", "acceptable": ["古典", "巴赫"]}]}]}
{"test_id": "conv_037", "title": "信息与闲聊混合", "description": "真正重要的信息混在大量闲聊中，Agent需要识别并记住关键事实", "category": "negative_sample", "difficulty": "hard", "total_turns": 12, "turns": [{"turn": 1, "user": "今天我心情特别好，天气也舒服。", "expected_facts_introduced": []}, {"turn": 2, "user": "对了说个正事，我对青霉素过敏，看病的时候必须告诉医生。", "expected_facts_introduced": ["过敏: 青霉素"]}, {"turn": 3, "user": "我昨天看了个综艺节目特别好笑。", "expected_facts_introduced": []}, {"turn": 4, "user": "中午吃了个三明治，味道一般。", "expected_facts_introduced": []}, {"turn": 5, "user": "哦还有，我下周三有个重要的面试，是去微软。", "expected_facts_introduced": ["面试: 下周三微软"]}, {"turn": 6, "user": "下午准备去健身房跑跑步。", "expected_facts_introduced": []}, {"turn": 7, "user": "晚上约了朋友吃火锅。", "expected_facts_introduced": []}, {"turn": 8, "user": "火锅我还是喜欢吃重庆的麻辣锅底。", "expected_facts_introduced": []}, {"turn": 9, "user": "今天地铁特别挤，差点迟到。", "expected_facts_introduced": []}, {"turn": 10, "user": "公司的咖啡机又坏了，烦死了。", "expected_facts_introduced": []}, {"turn": 11, "user": "最近晚上老睡不好，可能是压力大。", "expected_facts_introduced": []}, {"turn": 12, "user": "我刚才说过我有什么药物过敏？我下周有什么重要安排？", "expected_facts_introduced": [], "checklist": [{"fact": "过敏: 青霉素", "acceptable": ["青霉素"]}, {"fact": "面试: 微软 下周三", "acceptable": ["微软", "面试", "下周三"]}]}]}
{"test_id": "conv_038", "title": "功能测试: 确认无信息时诚实回答", "description": "用户未透露任何个人信息，Agent应诚实表示没有记住什么", "category": "negative_sample", "difficulty": "easy", "total_turns": 5, "turns": [{"turn": 1, "user": "能帮我算一下375乘以42等于多少吗？", "expected_facts_introduced": []}, {"turn": 2, "user": "谢谢，再帮我翻译一个句子到英文：今天天气很好。", "expected_facts_introduced": []}, {"turn": 3, "user": "再推荐几个好用的笔记应用。", "expected_facts_introduced": []}, {"turn": 4, "user": "Python里list和tuple有什么区别？", "expected_facts_introduced": []}, {"turn": 5, "user": "从我们的对话中，你了解了我的什么个人信息？", "expected_facts_introduced": [], "checklist": [{"fact": "无个人信息", "acceptable": ["没有", "不知道", "没记住", "没有信息"]}]}]}
