{"test_id": "conv_001", "title": "基本身份信息分散", "description": "用户在对话中分散提及姓名、年龄、职业、家乡，末尾逐条检核", "category": "fact_scatter", "difficulty": "easy", "total_turns": 9, "turns": [{"turn": 1, "user": "你好！我叫张明，很高兴认识你。", "expected_facts_introduced": ["姓名: 张明"]}, {"turn": 2, "user": "今天天气真不错，适合出去走走。", "expected_facts_introduced": []}, {"turn": 3, "user": "我今年25岁，刚工作没多久。", "expected_facts_introduced": ["年龄: 25"]}, {"turn": 4, "user": "能帮我推荐一些适合新人的理财方法吗？", "expected_facts_introduced": []}, {"turn": 5, "user": "我目前在杭州一家互联网公司做产品经理。", "expected_facts_introduced": ["地点: 杭州", "职业: 产品经理"]}, {"turn": 6, "user": "产品经理这个岗位有什么需要特别注意的地方吗？", "expected_facts_introduced": []}, {"turn": 7, "user": "对了，我老家是四川成都的，不是杭州本地人。", "expected_facts_introduced": ["家乡: 成都"]}, {"turn": 8, "user": "成都和杭州的生活节奏差别还挺大的。", "expected_facts_introduced": []}, {"turn": 9, "user": "我之前告诉过你我叫什么名字？我今年多大了？我在哪个城市工作？我的职业是什么？我老家是哪的？", "expected_facts_introduced": [], "checklist": [{"fact": "姓名: 张明", "acceptable": ["张明"]}, {"fact": "年龄: 25", "acceptable": ["25", "二十五"]}, {"fact": "地点: 杭州", "acceptable": ["杭州"]}, {"fact": "职业: 产品经理", "acceptable": ["产品经理"]}, {"fact": "家乡: 成都", "acceptable": ["成都", "四川成都"]}]}]}
{"test_id": "conv_002", "title": "饮食与生活习惯偏好", "description": "用户在多轮中分散提及饮食限制、作息、运动习惯", "category": "fact_scatter", "difficulty": "medium", "total_turns": 10, "turns": [{"turn": 1, "user": "我最近在减肥，想控制一下饮食。", "expected_facts_introduced": ["目标: 减肥"]}, {"turn": 2, "user": "有什么低卡路里又好吃的菜推荐吗？", "expected_facts_introduced": []}, {"turn": 3, "user": "对了，我对花生过敏，所以任何含花生的东西都不能吃。", "expected_facts_introduced": ["过敏: 花生"]}, {"turn": 4, "user": "我一般晚上11点睡觉，早上6点半起床。", "expected_facts_introduced": ["作息: 晚11早6:30"]}, {"turn": 5, "user": "早起适合做些什么运动呢？", "expected_facts_introduced": []}, {"turn": 6, "user": "我每周会跑步三次，每次大概5公里。", "expected_facts_introduced": ["运动: 每周跑步三次5公里"]}, {"turn": 7, "user": "跑步前后应该怎么拉伸？", "expected_facts_introduced": []}, {"turn": 8, "user": "我也比较喜欢游泳，但最近泳池都关门了。", "expected_facts_introduced": ["爱好: 游泳"]}, {"turn": 9, "user": "有没有其他不伤膝盖的有氧运动推荐？", "expected_facts_introduced": []}, {"turn": 10, "user": "我之前跟你说过我在减肥对吧？还有我对什么过敏？我一般几点睡觉？我每周跑步几次？我还喜欢什么运动？", "expected_facts_introduced": [], "checklist": [{"fact": "目标: 减肥", "acceptable": ["减肥"]}, {"fact": "过敏: 花生", "acceptable": ["花生过敏", "花生"]}, {"fact": "作息: 晚11早6点半", "acceptable": ["11点", "6点半", "6:30"]}, {"fact": "运动: 跑步每周三次", "acceptable": ["跑步", "5公里", "三次"]}]}]}
